{
    "name": "onlyoffice/onlyoffice-nextcloud",
    "authors": [
        {
            "name": "Ascensio System SIA",
            "email": "integration@onlyoffice.com",
            "homepage": "https://www.onlyoffice.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "OCA\\Onlyoffice\\": "./lib/"
        }
    },
    "scripts": {
        "test:unit": "vendor-bin/phpunit/vendor/bin/phpunit",
        "psalm": "vendor-bin/psalm/vendor/bin/psalm --no-cache --threads=$(nproc)",
        "psalm:dev": "@psalm",
        "psalm:update-baseline": "vendor-bin/psalm/vendor/bin/psalm --threads=1 --update-baseline --set-baseline=tests/psalm-baseline.xml",
        "test:integration": "vendor-bin/behat/vendor/bin/behat --config tests/integration/behat/config/behat.php"
    },
    "require": {
        "php": ">=8.1 <8.5",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.9"
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false
        }
    }
}
